{
  "name": "memoria-ai-flashcard-app-root",
  "private": true,
  "workspaces": [
    "nextjs-app",
    "ai-service"
  ],
  "dependencies": {
    "@clerk/nextjs": "^4.31.8",
    "@neondatabase/serverless": "^1.0.0",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30.6",
    "drizzle-orm": "^0.41.0"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate:pg --schema=./db/schema/index.ts",
    "db:migrate": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "dev:next": "cd nextjs-app && npm run dev",
    "dev:ai": "cd ai-service && python -m uvicorn app.main:app --reload",
    "build:next": "cd nextjs-app && npm run build",
    "install:all": "npm install && cd nextjs-app && npm install && cd ../ai-service && pip install -r requirements.txt"
  }
}
