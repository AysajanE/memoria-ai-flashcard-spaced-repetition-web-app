{
  "name": "nextjs-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \\\"**/*.{ts,tsx,js,jsx,md,json}\\\"",
    "format:check": "prettier --check \\\"**/*.{ts,tsx,js,jsx,md,json}\\\"",
    "test": "vitest run --reporter=verbose",
    "verify:no-app-db-imports": "node -e \\\"const {spawnSync}=require('node:child_process'); const r=spawnSync('rg',['-n','@/app/db','nextjs-app'],{stdio:'inherit'}); if(r.status===0){console.error('Error: Found forbidden @/app/db imports'); process.exit(1);} else { process.exit(0);} \\\"",
    "ci": "npm run lint && npm run test && npm run verify:no-app-db-imports",
    "db:generate": "drizzle-kit generate --config=./drizzle.config.ts",
    "db:migrate": "node -r dotenv/config ./scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@clerk/nextjs": "^4.29.9",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/supabase-js": "^2.39.3",
    "@types/pg": "^8.11.11",
    "@upstash/redis": "^1.35.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "geist": "^1.3.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.484.0",
    "next": "^14.2.25",
    "next-themes": "^0.4.6",
    "pg": "^8.14.1",
    "postgres": "^3.4.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.2",
    "svix": "^1.62.0",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.6",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.25",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^2.0.5"
  }
}
