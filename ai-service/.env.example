#####################################
# Example .env for AI Service (Python)
# Copy to .env.local and fill in values
#####################################

# -- SERVER CONFIG --
# The host and port on which the FastAPI app runs
API_HOST=0.0.0.0
API_PORT=8000

# Optional environment indicators for logging or debugging
ENVIRONMENT=development
LOG_LEVEL=INFO

# -- INTERNAL AUTH KEY --
# Shared secret for verifying requests between Next.js and this AI service
INTERNAL_API_KEY=your-internal-api-key-here
INTERNAL_WEBHOOK_HMAC_SECRET=optional-hmac-secret

# -- NEXT.JS WEBHOOK URL --
# The Next.js endpoint that receives AI job status updates
NEXTJS_APP_STATUS_WEBHOOK_URL=http://localhost:3000/api/webhooks/ai-service-status

# -- AI PROVIDER KEYS --
# OpenAI / Anthropic API keys, if you plan to use these providers
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# -- DEFAULT MODELS --
DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_ANTHROPIC_MODEL=claude-haiku-3-5-latest

# (Optional) JSON-encoded object of model settings for advanced usage
AI_MODELS='{
  "gpt-4o-mini": {
    "provider": "openai",
    "max_input_tokens": 128000,
    "max_output_tokens": 4096,
    "description": "Efficient, cost-effective OpenAI model"
  },
  "gpt-3.5-turbo": {
    "provider": "openai",
    "max_input_tokens": 16385,
    "max_output_tokens": 4096,
    "description": "Cheaper but older model"
  },
  "claude-haiku-3-5-latest": {
    "provider": "anthropic",
    "max_input_tokens": 200000,
    "max_output_tokens": 4096,
    "description": "Fast, efficient Anthropic model"
  }
}'

# -- PHASE 4 RELIABILITY FEATURES --
# Enable automatic model fallback when primary models fail
ENABLE_FALLBACK=true

# Enable circuit breaker pattern to prevent cascade failures
ENABLE_CIRCUIT_BREAKER=true

# Redis URL for circuit breaker state persistence (optional)
# If not provided, circuit breakers will use in-memory state
REDIS_URL=redis://localhost:6379/0

# -- CORS SETTINGS --
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -- TOKEN LIMITS --
# Maximum input/output tokens per request
MAX_INPUT_TOKENS=10000
MAX_OUTPUT_TOKENS=4096
