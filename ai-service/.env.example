# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# AI Service Base URL
AI_SERVICE_BASE_URL = http://localhost:8000

# Authentication
INTERNAL_API_KEY=your-internal-api-key-here

# AI Service Configuration
