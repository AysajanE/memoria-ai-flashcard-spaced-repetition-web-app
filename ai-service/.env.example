# Environment
ENVIRONMENT=development

# AI Provider Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Security
INTERNAL_WEBHOOK_HMAC_SECRET=your-secret-key

# Feature Flags
USE_QUEUE=false
ENABLE_FALLBACK=false
ENABLE_PROGRESS_UPDATES=false
ENABLE_COST_ACCOUNTING=false
ENABLE_INBOUND_HMAC=false

# Concurrency & Budgets
OPENAI_MAX_CONCURRENCY=8
ANTHROPIC_MAX_CONCURRENCY=8
TOKENS_PER_CARD_BUDGET=128
MAX_OUTPUT_TOKENS=2048

# Infrastructure
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000

# AI Models (JSON string)
AI_MODELS={}

# Legacy fields for backwards compatibility
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
INTERNAL_API_KEY=your-internal-secret-key
NEXTJS_APP_STATUS_WEBHOOK_URL=http://localhost:3000/api/webhooks/ai-status
DEFAULT_OPENAI_MODEL=gpt-4o-mini
DEFAULT_ANTHROPIC_MODEL=claude-haiku-3-5-latest

# -- FEATURE FLAGS --
USE_QUEUE=false
ENABLE_FALLBACK=false
ENABLE_PROGRESS_UPDATES=false
ENABLE_COST_ACCOUNTING=false
ENABLE_INBOUND_HMAC=false

# -- CONCURRENCY & BUDGETS --
OPENAI_MAX_CONCURRENCY=8
ANTHROPIC_MAX_CONCURRENCY=8
TOKENS_PER_CARD_BUDGET=128

# -- INFRASTRUCTURE --
REDIS_URL=redis://localhost:6379/0

# -- TOKEN LIMITS --
MAX_INPUT_TOKENS=10000
MAX_OUTPUT_TOKENS=2048

# (Optional) JSON-encoded object of model settings for advanced usage
AI_MODELS='{
  "gpt-4o-mini": {
    "provider": "openai",
    "max_input_tokens": 128000,
    "max_output_tokens": 4096,
    "description": "Efficient, cost-effective OpenAI model"
  },
  "gpt-3.5-turbo": {
    "provider": "openai",
    "max_input_tokens": 16385,
    "max_output_tokens": 4096,
    "description": "Cheaper but older model"
  },
  "claude-haiku-3-5-latest": {
    "provider": "anthropic",
    "max_input_tokens": 200000,
    "max_output_tokens": 4096,
    "description": "Fast, efficient Anthropic model"
  }
}'
